rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
       return !('uid' in request.resource.data) ||
         request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
       return !('uid' in request.resource.data) ||
         request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
       return request.resource.data[field] is string &&
         request.resource.data[field].size() >= minLen &&
         request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidSite() {
      return hasRequiredFields(['id', 'site', 'username', 'applicationPassword', 'name', 'uid', 'createdAt']) &&
             validStringLength('id', 1, 50) &&
             validStringLength('site', 1, 200) &&
             validStringLength('username', 1, 100) &&
             validStringLength('applicationPassword', 1, 100) &&
             validStringLength('name', 1, 100) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.createdAt is number;
    }

    function isValidLog() {
      return hasRequiredFields(['id', 'timestamp', 'level', 'message', 'uid', 'createdAt']) &&
             validStringLength('id', 1, 50) &&
             validStringLength('timestamp', 1, 50) &&
             request.resource.data.level in ['info', 'success', 'error', 'warning'] &&
             validStringLength('message', 1, 1000) &&
             (!('site' in request.resource.data) || validStringLength('site', 0, 100)) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.createdAt is number;
    }

    function isValidSettings() {
      return hasRequiredFields(['uid', 'updatedAt']) &&
             (!('googleApiKey' in request.resource.data) || validStringLength('googleApiKey', 0, 100)) &&
             (!('googleCx' in request.resource.data) || validStringLength('googleCx', 0, 100)) &&
             (!('unsplashApiKey' in request.resource.data) || validStringLength('unsplashApiKey', 0, 100)) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      match /sites/{siteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSite() && uidUnchanged();
        allow update: if isOwner(userId) && isValidSite() && uidNotModified();
        allow delete: if isOwner(userId);
      }
      
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLog() && uidUnchanged();
        allow update: if isOwner(userId) && isValidLog() && uidNotModified();
        allow delete: if isOwner(userId);
      }
      
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSettings() && uidUnchanged();
        allow update: if isOwner(userId) && isValidSettings() && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }
  }
}
